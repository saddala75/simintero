# .env.example — copy to .env and fill in secrets for production
# NEVER commit .env to git (it is in .gitignore)
#
# Usage:
#   cp .env.example .env
#   # Edit .env with real values
#   docker compose --env-file .env up -d

# ── SMTP — email notice delivery ─────────────────────────────────────────────
# Local dev: leave unset — docker-compose defaults to mailpit (http://localhost:8025)
# Production: set to your real SMTP relay
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=changeme

# ── OIDC audiences ────────────────────────────────────────────────────────────
# Must match the Keycloak client IDs in the simintero realm.
WORKFLOW_OIDC_AUDIENCE=enstellar-workflow
BFF_OIDC_AUDIENCE=enstellar-bff

# ── Portal origin (used by Keycloak CORS webOrigins) ─────────────────────────
PORTAL_ORIGIN=https://portal.example.com

# ── Database secrets — REPLACE ALL IN PRODUCTION ─────────────────────────────
POSTGRES_PASSWORD=changeme-strong-password
KC_DB_PASSWORD=changeme-strong-password

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_PASSWORD=changeme-strong-password

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=changeme-strong-password

# ── Optional external integrations ───────────────────────────────────────────
# Leave blank in dev; set in production/staging.
ANTHROPIC_API_KEY=
VSAC_API_KEY=
CLEARINGHOUSE_API_KEY=
