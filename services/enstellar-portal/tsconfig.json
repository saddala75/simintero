{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@sim/design-system": ["../../packages/design-system/src/index.ts"],
      "@sim/reviewer-workspace/*": ["../../apps/web/reviewer-workspace/src/*"],
      "@sim/digicore-console/*": ["../../apps/web/digicore-console/src/*"],
      "@sim/quality-console/*": ["../../apps/web/quality-console/src/*"],
      "@sim/analytics-console/*": ["../../apps/web/analytics-console/src/*"],
      "@sim/ai-ops-console/*": ["../../apps/web/ai-ops-console/src/*"],
      "@sim/saas-admin/*": ["../../apps/web/saas-admin/src/*"],
      "@sim/support-console/*": ["../../apps/web/support-console/src/*"]
    },
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src",
    "../../apps/web/reviewer-workspace/src/**/*",
    "../../apps/web/digicore-console/src/**/*",
    "../../apps/web/quality-console/src/**/*",
    "../../apps/web/analytics-console/src/**/*",
    "../../apps/web/ai-ops-console/src/**/*",
    "../../apps/web/saas-admin/src/**/*",
    "../../apps/web/support-console/src/**/*"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
