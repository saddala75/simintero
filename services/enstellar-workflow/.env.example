# Enstellar Workflow Environment Configuration Example
# Copy this file to .env and update with your actual values

# Database configuration
WORKFLOW_DB_URL=postgresql+asyncpg://workflow:workflow_secret@localhost:5432/workflow
SIMINTERO_DB_URL=postgresql://sim_app:devpassword@localhost:5432/simintero

# Kafka configuration
WORKFLOW_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# OIDC / Keycloak configuration
WORKFLOW_OIDC_ISSUER=http://localhost:8081/realms/simintero
WORKFLOW_KEYCLOAK_JWKS_URL=http://localhost:8080/realms/simintero/protocol/openid-connect/certs
WORKFLOW_OIDC_AUDIENCE=enstellar-workflow

# OPA authorization
WORKFLOW_OPA_URL=http://localhost:8181

# MinIO object storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=enstellar-raw-bundles

# Digicore runtime
DIGICORE_BASE_URL=http://localhost:8083

# Document service
WORKFLOW_DOCUMENT_SERVICE_URL=http://localhost:3010

# Revital pipeline
REVITAL_BASE_URL=http://localhost:3014

# SMTP configuration (for email notice delivery)
WORKFLOW_SMTP_HOST=mailhog
WORKFLOW_SMTP_PORT=1025
WORKFLOW_SMTP_USERNAME=
WORKFLOW_SMTP_PASSWORD=
WORKFLOW_SMTP_FROM_ADDR=noreply@simintero.local

# SLA polling interval (in seconds)
WORKFLOW_SLA_POLL_INTERVAL_SECONDS=5

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=enstellar-workflow
