{
  "name": "@sim/outbox-ts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./relay": {
      "types": "./src/relay.ts",
      "default": "./dist/relay.js"
    },
    "./append": {
      "types": "./src/append.ts",
      "default": "./dist/append.js"
    }
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "pg": ">=8"
  }
}
