{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.simintero.io/event-envelope/v1",
  "title": "EventEnvelope",
  "type": "object",
  "required": ["event_id","schema_ref","occurred_at","tenant","correlation_id","actor","payload"],
  "additionalProperties": false,
  "properties": {
    "event_id":       { "type": "string", "pattern": "^evt_[0-9A-Z]{26}$" },
    "schema_ref":     { "type": "string", "description": "e.g. sim.case.state-changed/v2" },
    "occurred_at":    { "type": "string", "format": "date-time" },
    "tenant": {
      "type": "object",
      "required": ["tenant_id"],
      "properties": {
        "tenant_id":  { "type": "string" },
        "lob":        { "type": "string", "enum": ["MA","MEDICAID","COMMERCIAL","PUBLIC"] },
        "program":    { "type": ["string","null"] },
        "product":    { "type": ["string","null"] },
        "region":     { "type": ["string","null"] }
      }
    },
    "correlation_id": { "type": "string", "description": "case_id or transaction spine" },
    "causation_id":   { "type": ["string","null"] },
    "actor": {
      "type": "object",
      "required": ["type","id"],
      "properties": {
        "type":          { "type": "string", "enum": ["human","service","model_agent"] },
        "id":            { "type": "string" },
        "on_behalf_of":  { "type": ["string","null"] }
      }
    },
    "trace_ref":  { "type": ["string","null"] },
    "payload":    { "type": "object" }
  }
}
