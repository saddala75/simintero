{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "Kafka consumer lag, DB latency, Temporal worker backlog",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(messaging_receive_lag{system=\"kafka\"}) by (messaging_destination_name)",
          "legendFormat": "lag: {{messaging_destination_name}}",
          "refId": "A"
        }
      ],
      "title": "Kafka Consumer Lag by Topic",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum(rate(db_client_operation_duration_seconds_bucket[5m])) by (le, service_name)) * 1000",
          "legendFormat": "p95 {{service_name}}",
          "refId": "A"
        }
      ],
      "title": "DB Query p95 Latency by Service",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "otel_collector_receiver_accepted_spans_total",
          "legendFormat": "Spans accepted",
          "refId": "A"
        }
      ],
      "title": "OTel Collector — Spans Ingested",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["simintero", "infra"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Infrastructure",
  "uid": "infrastructure",
  "version": 1
