{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "Prior Authorization lifecycle latency and SLA compliance",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_milliseconds_bucket{service_name=~\"enstellar.*\"}[5m])) by (le, service_name))",
          "legendFormat": "p50 {{service_name}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket{service_name=~\"enstellar.*\"}[5m])) by (le, service_name))",
          "legendFormat": "p95 {{service_name}}",
          "refId": "B"
        }
      ],
      "title": "PA Service Latency (p50/p95)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(increase(http_server_response_count_total{service_name=~\"enstellar.*\", http_response_status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx errors (5m)",
          "refId": "A"
        }
      ],
      "title": "PA Service Errors (5xx, 5m window)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "id": 3,
      "options": {"legend": {"displayMode": "list"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum(rate(db_client_operation_duration_seconds_bucket{service_name=~\"enstellar.*\"}[5m])) by (le, service_name)) * 1000",
          "legendFormat": "DB p95 {{service_name}}",
          "refId": "A"
        }
      ],
      "title": "PA Service DB Query Latency p95",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["simintero", "pa", "sla"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "PA Lifecycle SLA",
  "uid": "pa-lifecycle-sla",
  "version": 1
}
